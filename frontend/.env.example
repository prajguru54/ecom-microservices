# Relative path: frontend/.env
# Copy to frontend/.env for local development.

# Browser-side catalog base. In local npm dev, vite proxy forwards /api -> gateway-service:8003.
VITE_CATALOG_BASE_URL=/api

# Server-runtime catalog base (must be absolute URL when running loaders outside browser).
# Local npm dev option:
VITE_CATALOG_SERVER_URL=http://127.0.0.1:8003/api

# Docker option:
# VITE_CATALOG_SERVER_URL=http://gateway-service:8003/api

# Frontend build-time API routing (used by docker-compose frontend build args)
FRONTEND_CATALOG_BASE_URL=/api
# Comment one the below two options depending on how you run the frontend
# FRONTEND_CATALOG_SERVER_URL=http://gateway-service:8003/api # for local npm dev
FRONTEND_CATALOG_SERVER_URL=http://gateway-service:8003/api # when running inside Docker network.

