# Env file path: .env.example

# PostgreSQL
POSTGRES_USER=ecom_user
POSTGRES_PASSWORD=change_me
POSTGRES_DEFAULT_DB=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_AUTH_DB=auth_db
POSTGRES_CATALOG_DB=catalog_db
POSTGRES_CART_DB=cart_db
POSTGRES_ORDER_DB=order_db
POSTGRES_INVENTORY_DB=inventory_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_DEFAULT_USER=ecom_mq_user
RABBITMQ_DEFAULT_PASS=change_me
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Monitoring
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me
NGINX_HTTP_PORT=8081
PROMETHEUS_PORT=9090

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me
PGADMIN_PORT=5050

# Shared JWT
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256

# Frontend build-time API routing (used by docker-compose frontend build args)
FRONTEND_CATALOG_BASE_URL=/api
FRONTEND_CATALOG_SERVER_URL=http://gateway-service:8003/api
