{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StockReservedEvent",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "occurred_at",
    "order_id",
    "reservation_status",
    "items"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "const": "inventory.reserved"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "order_id": {
      "type": "string",
      "format": "uuid"
    },
    "reservation_status": {
      "type": "string",
      "enum": [
        "success",
        "partial",
        "failed"
      ]
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "product_id",
          "requested_quantity",
          "reserved_quantity"
        ],
        "properties": {
          "product_id": {
            "type": "string",
            "format": "uuid"
          },
          "requested_quantity": {
            "type": "integer",
            "minimum": 1
          },
          "reserved_quantity": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
